# Discord bot runtime
# From setup-state botToken. Never commit a real bot token.
DISCORD_TOKEN=your_discord_bot_token

# Discord OAuth app for dashboard login
# From setup-state discordClientId / discordClientSecret.
DISCORD_CLIENT_ID=your_discord_application_client_id
DISCORD_CLIENT_SECRET=your_discord_application_client_secret

# Dashboard auth
# Local: http://localhost:3000
# Vercel: https://your-dashboard.vercel.app
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace_with_a_long_random_string

# Dashboard owner/admin Discord user ID
# From setup-state ownerDiscordId.
ADMIN_DISCORD_USER_ID=your_discord_user_id

# Treat env vars as an already-completed setup state.
# Useful for Vercel/serverless deployments where .setup-state.json is not persistent.
SETUP_COMPLETE=true
SELECTED_GUILD_ID=your_discord_server_id

# Supabase/Postgres connection
# From setup-state databaseUrl. Prefer Supabase Transaction Pooler with sslmode=require.
DATABASE_URL=postgresql://postgres.project-ref:password@aws-region.pooler.supabase.com:6543/postgres?sslmode=require
PG_SSL_MODE=require

# Optional channel defaults
# From setup-state logChannelId / lfgChannelId.
LOG_CHANNEL_ID=your_log_text_channel_id
LFG_CHANNEL_ID=your_lfg_text_channel_id

# Optional local development fallback only
SQLITE_PATH=./data/discord.db
DEBUG=false
